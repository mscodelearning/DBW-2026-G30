        <link rel="stylesheet" href="/css/offcanvas.css">
        <link rel="stylesheet" href="/css/salaPrivada.css">

        <title>Skriven</title>
    </head>
<body>
    <div>
        <%- include("partials/header") %>
    </div>


    <div class="botao-voltar-container">
        <img src="/images/botao-sair.png" alt="voltar">
        <div class="overlay-text">Sair</div>
        <a href="/selectMultiplayerPage"></a>
    </div>


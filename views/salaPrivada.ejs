    <div class="container-sala-privada">
        <div class="fundo-chat">
            <img class="fundo-caixa" src="/images/fundo-chat.png" alt="">
            <img class="fundo-bottom-chat" src="/images/fundo-caixa-chat.png" alt="">

            <div class="input-area">
            <img class="caixa-texto-chat" src="/images/caixa-texto-chat.png" alt="">
            
            <input 
                type="text" 
                id="mensagemInput" 
                class="input-chat" 
                placeholder="Escreve uma mensagem..."
            >

            <button id="sendBtn" class="btn-send" type="button" aria-label="Enviar mensagem">
                <img class="fundo-btn-send" src="/images/fundo-btn-send.png" alt="">
                <img class="icon-send" src="/symbols/aviao-send.png" alt="">
            </button>
            </div>

            <div class="mensagens" id="mensagens"></div>
        </div>
    </div>


    <div class="caixa-nomes-sala">
        <img class="nome-sala" src="/images/icon-nome-sala.png" alt="">
    </div>








    <div class="container-botao">
        <a href="#" id="procura-link">
                <div class="fundo-verde-botao-signup">
                    <div class="overlay-text-signup">Iniciar Jogo</div>
                        <img src="/images/retangulo-verde-botao-login.png" alt="fundo-botao-signup">
                </div>
            </a>
            <div class="botao-signup-container">
                <img src="/images/botao-login.png" alt="botao-signup">
            </div>
    </div>
    

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

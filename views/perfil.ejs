    <div class="botao-sair-container">
        <!--<img src="../public/images/botao-sair.png" alt="sair">-->
        <img src="/images/botao-sair.png" alt="sair">
        <div class="overlay-text-perfil">Sair</div>
        <!--<a href="selectMultiplayerPage.html"></a>-->
        <a href="/selectMultiplayerPage"></a>
    </div>
    <div class="container">
        <div  class="perfil-header">
            <div class="user-icon2-perfil-container">
                <!--<img id="perfil-img" src="../public/symbols/user-icon-2.png" alt="user-icon"> id novo-->
                <img id="perfil-img" src="/symbols/user-icon-2.png" alt="user-icon"> <!--id novo-->
            </div>
            <div class="alteraImagem-perfil-container">
                <!--<p>Alterar Imagem</p>-->
                <p id="texto-altera-imagem">Alterar Imagem</p>
                <div id="pop-up" class="popup">
                    <div class="conteudo-popup">
                        <!--<p>Este conteudo é do pop-up.</p>-->
                        <label  id="drop-area">
                            <input type="file" accept="image/*" id="input-file" hidden>
                            <div id="img-view">
                                <div class="upload-text">
                                    <!--<img src="../public/symbols/symbol_upload.png" alt="symbol-upload">-->
                                    <img src="/symbols/symbol_upload.png" alt="symbol-upload">
                                    <p>Drag and drop or click here<br> to upload image</p>
                                    <span> Upload any images from desktop</span>
                                </div>
                            </div>
                        </label>
                        <div class="botoes-popup">
                            <button type="button" id="btn-remover">Remover</button>
                            <button type="button" id="btn-aplicar">Aplicar</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="coluna-caixas">
            <div class="grupo-campo">
                <p class="label-campo">Nome exibido</p>
                <div class="caixa-texto-imagem">
                    <input type="text" id="nickname" placeholder="escreva o texto aqui">
                </div>
            </div>
            <div id="save-bar" role="alert" aria-live="polite">
                <div class="alert alert-success d-flex align-items-center justify-content-between shadow mb-0 gap-3">
                    <span>Tens alterações não guardadas.</span>
                    <div class="d-flex gap-2">
                    <button id="btn-reset" class="btn btn-secondary btn-sm" type="button">Redefinir</button>
                    <button id="btn-save" class="btn btn-success btn-sm" type="button">Salvar alterações</button>
                    </div>
                </div>
            </div>
            <div class="grupo-campo">
                <p class="label-campo">Nome de Utilizador</p>
                <div class="caixa-texto-imagem">
                    <input type="text" placeholder="escreva o texto aqui">
                </div>
            </div>
            <div class="grupo-campo">
                <p class="label-campo">Palavra-passe</p>
                <div class="caixa-texto-imagem">
                    <input type="password" placeholder="escreva o texto aqui">
                </div>
            </div>
            <!--<a href="alteraPalavraPasse.html" class="texto-alterar-password">-->
            <a href="/alterarPalavraPasse" class="texto-alterar-password">
                Alterar palavra-passe
            </a>
        </div>
        <div class="quadro-estatistico-container">
            <!--<img class="img-quadro" src="../public/images/quadro-estatisticas-perfil.png" alt="quadro-madeira">-->
            <img class="img-quadro" src="/images/quadro-estatisticas-perfil.png" alt="quadro-madeira">
            <div class="fundo-verde-quadro-estatistico">
                <!--<img class="img-fundo-verde" src="../public/images/fundo-quadro-estatisticas.png" alt="fundo-verde">-->
                <img class="img-fundo-verde" src="/images/fundo-quadro-estatisticas.png" alt="fundo-verde">
                <div class="stats-overlay">
                    <h3 class="stats-title">Estatísticas</h3>
                    <div class="stat-item">
                        <span class="stat-label">Total pontos</span>
                        <span class="stat-value" id="total-pontos">1250</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Respostas encontradas</span>
                        <span class="stat-value" id="respostas-encontradas">34</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Respostas erradas</span>
                        <span class="stat-value" id="respostas-erradas">12</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Tempo total de jogo</span>
                        <span class="stat-value" id="tempo-total">04:32</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="zona-botao-termina">
